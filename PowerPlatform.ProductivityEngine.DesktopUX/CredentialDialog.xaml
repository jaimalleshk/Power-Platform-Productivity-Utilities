<Window x:Class="PowerPlatform.ProductivityEngine.DesktopUX.CredentialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Microsoft Power Platform Authentication &amp; Discovery" Height="300" Width="480"
        Background="#0F172A" Foreground="#F8FAFC" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔐 Discover Tenant Environments (OAuth 2.0)" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" Text="Client User Email / UPN (e.g. user@clientcompany.com):" Foreground="#CBD5E1" Margin="0,0,0,4"/>
        <TextBox Grid.Row="2" x:Name="TxtUsername" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Padding="8,6" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="3" Text="Azure Tenant ID (Optional - leave blank for Common):" Foreground="#CBD5E1" Margin="0,0,0,4"/>
        <TextBox Grid.Row="4" x:Name="TxtTenantId" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Padding="8,6" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancelClick" Background="#334155" Foreground="White" Width="90" Height="32" Margin="0,0,10,0" BorderThickness="0"/>
            <Button Content="🔑 Sign In &amp; Discover" Click="OnSignInClick" Background="#0284C7" Foreground="White" FontWeight="Bold" Width="160" Height="32" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
