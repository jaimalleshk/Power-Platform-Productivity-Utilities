<Window x:Class="PowerPlatform.ProductivityEngine.DesktopUX.CredentialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Microsoft Power Platform Authentication &amp; Discovery" Height="290" Width="520"
        Background="#0F172A" Foreground="#F8FAFC" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔐 Discover Tenant Environments (OAuth 2.0)" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="1" Text="Client User Email / UPN (Auto-Complete &amp; Saved History):" Foreground="#CBD5E1" Margin="0,0,0,4"/>
        
        <!-- Editable ComboBox with High Contrast Dark Theme Styles -->
        <ComboBox Grid.Row="2" x:Name="CmbUsername" IsEditable="True" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Padding="6,4" Margin="0,0,0,10" FontSize="13">
            <ComboBox.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#1E293B"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#F8FAFC"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0284C7"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
            </ComboBox.Resources>
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="Foreground" Value="#F8FAFC"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#0284C7"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>

        <CheckBox Grid.Row="3" x:Name="ChkAutoConnect" Content="Remember login credentials &amp; enable silent Single Sign-On (SSO)" IsChecked="True" Foreground="#38BDF8" FontSize="11" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4" Text="✨ Azure Tenant ID: Auto-Discovered automatically from domain" Foreground="#34D399" FontSize="11" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnCancelClick" Background="#334155" Foreground="White" Width="90" Height="32" Margin="0,0,10,0" BorderThickness="0"/>
            <Button Content="🔑 Sign In &amp; Discover" Click="OnSignInClick" Background="#0284C7" Foreground="White" FontWeight="Bold" Width="160" Height="32" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
