<Window x:Class="PowerPlatform.ProductivityEngine.DesktopUX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PowerPlatform.ProductivityEngine.DesktopUX.ViewModels"
        Title="Power Platform Environment Comparator (WPF .NET 9)" Height="768" Width="1200"
        Background="#0F172A" Foreground="#F8FAFC" WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR & CONTROLS -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="⚡ POWER PLATFORM ENVIRONMENT COMPARATOR" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="🚀 Discover Envs (OAuth)" Command="{Binding DiscoverEnvironmentsCommand}" Background="#334155" Foreground="White" Padding="10,6" Margin="0,0,8,0" BorderThickness="0"/>
                    <Button Content="🔄 Compare Environments" Command="{Binding CompareEnvironmentsCommand}" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="14,6" Margin="0,0,16,0" BorderThickness="0"/>
                    <CheckBox Content="Simulation Mode (Offline Demo)" IsChecked="{Binding IsSimulationMode}" Foreground="#94A3B8" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="📊 Export HTML Dashboard" Command="{Binding ExportHtmlCommand}" Background="#166534" Foreground="White" Padding="10,6" Margin="0,0,8,0" BorderThickness="0"/>
                    <Button Content="📄 Export Excel / CSV Matrix" Command="{Binding ExportCsvCommand}" Background="#1E3A8A" Foreground="White" Padding="10,6" BorderThickness="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN SPLIT CONTENT -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR: ENVS & 2-ROOT TREE -->
            <Border Grid.Column="0" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,12,0" BorderBrush="#334155" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Auto-Discovery Listbox -->
                        <TextBlock Text="🌐 DISCOVERED ENVIRONMENTS" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,6"/>
                        <ListBox ItemsSource="{Binding DiscoveredEnvironments}" Background="#0F172A" BorderBrush="#334155" Height="100" Margin="0,0,0,12">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Foreground="#F8FAFC" Margin="4,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Scope Checkboxes -->
                        <TextBlock Text="🎛️ SCOPE SELECTION" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,6"/>
                        <CheckBox Content="Admin &amp; OrgDbOrgSettings" IsChecked="{Binding Scope.CompareAdminSettings}" Foreground="#CBD5E1" Margin="4,2"/>
                        <CheckBox Content="Plug-in Assemblies &amp; Steps" IsChecked="{Binding Scope.ComparePluginsAndSteps}" Foreground="#CBD5E1" Margin="4,2"/>
                        <CheckBox Content="Environment Variables" IsChecked="{Binding Scope.CompareEnvironmentVariables}" Foreground="#CBD5E1" Margin="4,2"/>
                        <CheckBox Content="Cloud Flows &amp; Automations" IsChecked="{Binding Scope.CompareCloudFlowsAndWorkflows}" Foreground="#CBD5E1" Margin="4,2"/>
                        <CheckBox Content="Tables &amp; Columns (Schema)" IsChecked="{Binding Scope.CompareTablesAndColumns}" Foreground="#CBD5E1" Margin="4,2"/>
                        <CheckBox Content="Web Resources &amp; Forms" IsChecked="{Binding Scope.CompareWebResources}" Foreground="#CBD5E1" Margin="4,2"/>
                        <CheckBox Content="Security Roles &amp; Privileges" IsChecked="{Binding Scope.CompareSecurityRoles}" Foreground="#CBD5E1" Margin="4,2"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- CENTRAL COMPARISON MATRIX PANE -->
            <Border Grid.Column="1" Background="#1E293B" CornerRadius="8" Padding="12" BorderBrush="#334155" BorderThickness="1">
                <TabControl Background="Transparent" BorderThickness="0">
                    <TabItem Header="📁 Root 1: Admin &amp; Env Settings" Foreground="#38BDF8" FontSize="14" FontWeight="Bold">
                        <DataGrid ItemsSource="{Binding AdminSettingsTree}" SelectedItem="{Binding SelectedNode}" AutoGenerateColumns="False" IsReadOnly="True" Background="#0F172A" Foreground="#F8FAFC" RowBackground="#1E293B" AlternatingRowBackground="#0F172A" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#334155">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category" Binding="{Binding SubCategory}" Width="140"/>
                                <DataGridTextColumn Header="Setting Name" Binding="{Binding DisplayName}" Width="200"/>
                                <DataGridTextColumn Header="Diff Status" Binding="{Binding Status}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem Header="📁 Root 2: Solution Explorer (Forms, Views, Plugins, Flows)" Foreground="#38BDF8" FontSize="14" FontWeight="Bold">
                        <TreeView ItemsSource="{Binding MetadataTree}" Background="#0F172A" Foreground="#F8FAFC" BorderThickness="0" Margin="4">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <TextBlock Text="{Binding DisplayName}" Foreground="#F8FAFC" FontWeight="SemiBold" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Status}" Foreground="#38BDF8" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- BOTTOM SPLIT PANE: PROPERTY & CODE DIFF INSPECTOR -->
        <Border Grid.Row="2" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,8" BorderBrush="#334155" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="🔍 DEEP PROPERTY &amp; VALUE INSPECTOR" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,8"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedNodeProperties}" AutoGenerateColumns="False" IsReadOnly="True" Background="#0F172A" Foreground="#F8FAFC" RowBackground="#1E293B" AlternatingRowBackground="#0F172A" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#334155">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Property Name" Binding="{Binding PropertyName}" Width="220"/>
                        <DataGridCheckBoxColumn Header="Is Mismatch?" Binding="{Binding IsMismatch}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#0F172A" Padding="6,4">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="12"/>
        </Border>
    </Grid>
</Window>
