<Window x:Class="PowerPlatform.ProductivityEngine.DesktopUX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PowerPlatform.ProductivityEngine.DesktopUX.ViewModels"
        Title="Power Platform Environment Comparator &amp; Solution Explorer (.NET 9)" Height="850" Width="1350"
        Background="#0F172A" Foreground="#F8FAFC" WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR & CONTROLS -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#334155" BorderThickness="1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="⚡ POWER PLATFORM COMPARATOR" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="🔑 Discover Envs (OAuth)" Command="{Binding DiscoverEnvironmentsCommand}" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="12,6" Margin="0,0,8,0" BorderThickness="0"/>
                    <Button Content="🔄 Run Compare / Explore" Command="{Binding CompareEnvironmentsCommand}" Background="#166534" Foreground="White" FontWeight="Bold" Padding="14,6" Margin="0,0,16,0" BorderThickness="0"/>
                    <CheckBox Content="Simulation Mode (Offline Demo)" IsChecked="{Binding IsSimulationMode}" Foreground="#94A3B8" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="📊 Export HTML Dashboard" Command="{Binding ExportHtmlCommand}" Background="#334155" Foreground="White" Padding="10,6" Margin="0,0,6,0" BorderThickness="0"/>
                    <Button Content="📗 Export Formatted Excel" Command="{Binding ExportExcelCommand}" Background="#0D9488" Foreground="White" FontWeight="Bold" Padding="10,6" Margin="0,0,6,0" BorderThickness="0"/>
                    <Button Content="🗄️ Save Offline SQLite" Command="{Binding SaveToSqliteCommand}" Background="#4338CA" Foreground="White" Padding="10,6" BorderThickness="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN SPLIT CONTENT -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANE: ENVS & UNIFIED SOLUTION EXPLORER TREE (ROOT 1 & ROOT 2) -->
            <Border Grid.Column="0" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,12,0" BorderBrush="#334155" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Discovered Environments List -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="🌐 DISCOVERED ENVIRONMENTS" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,4"/>
                        <ListBox ItemsSource="{Binding DiscoveredEnvironments}" Background="#0F172A" BorderBrush="#334155" Height="80">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Foreground="#F8FAFC" Margin="4,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- Solution Explorer Controls Header -->
                    <DockPanel Grid.Row="1" Margin="0,0,0,6" LastChildFill="False">
                        <TextBlock Text="📁 SOLUTION EXPLORER TREE" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="➕ Expand All" Command="{Binding ExpandAllCommand}" Background="#334155" Foreground="White" Padding="6,3" Margin="0,0,4,0" FontSize="11" BorderThickness="0"/>
                            <Button Content="➖ Collapse All" Command="{Binding CollapseAllCommand}" Background="#334155" Foreground="White" Padding="6,3" FontSize="11" BorderThickness="0"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Unified Root 1 & Root 2 TreeView -->
                    <TreeView Grid.Row="2" ItemsSource="{Binding UnifiedSolutionExplorerTree}" SelectedItemChanged="TreeView_SelectedItemChanged" Background="#0F172A" Foreground="#F8FAFC" BorderThickness="0">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="2">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#F8FAFC" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Status}" Foreground="#38BDF8" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- RIGHT PANE: DATA FOR SELECTED ITEM IN LEFT PANE -->
            <Border Grid.Column="1" Background="#1E293B" CornerRadius="8" Padding="14" BorderBrush="#334155" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="140"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Selected Item Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍 SELECTED ITEM DATA: " FontWeight="Bold" Foreground="#94A3B8" FontSize="14"/>
                            <TextBlock Text="{Binding SelectedNode.DisplayName, FallbackValue='(Select an item in left tree)'}" FontWeight="Bold" Foreground="#38BDF8" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Unique Key: " Foreground="#64748B" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedNode.UniqueKey}" Foreground="#CBD5E1" FontSize="11" Margin="0,0,16,0"/>
                            <TextBlock Text="Diff Status: " Foreground="#64748B" FontSize="11"/>
                            <TextBlock Text="{Binding SelectedNode.Status}" Foreground="#38BDF8" FontWeight="Bold" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Top Table: Values Per Environment for Selected Node -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="🌐 Environment Values Summary" FontWeight="Bold" Foreground="#CBD5E1" Margin="0,0,0,4"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedNode.EnvironmentValues}" AutoGenerateColumns="False" IsReadOnly="True" Background="#0F172A" Foreground="#F8FAFC" RowBackground="#1E293B" AlternatingRowBackground="#0F172A" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#334155">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Environment Name" Binding="{Binding Key}" Width="200"/>
                                <DataGridTextColumn Header="Value / Version / Status" Binding="{Binding Value}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Bottom Table: Detailed Property Mismatch Matrix for Selected Node -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📋 Property-Level Diff &amp; Value Breakdown" FontWeight="Bold" Foreground="#CBD5E1" Margin="0,0,0,4"/>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedNodeProperties}" AutoGenerateColumns="False" IsReadOnly="True" Background="#0F172A" Foreground="#F8FAFC" RowBackground="#1E293B" AlternatingRowBackground="#0F172A" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#334155">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Property Name" Binding="{Binding PropertyName}" Width="220"/>
                                <DataGridCheckBoxColumn Header="Is Mismatch?" Binding="{Binding IsMismatch}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#0F172A" Padding="6,4">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="12"/>
        </Border>
    </Grid>
</Window>
