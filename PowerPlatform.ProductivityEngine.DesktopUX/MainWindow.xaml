<Window x:Class="PowerPlatform.ProductivityEngine.DesktopUX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PowerPlatform.ProductivityEngine.DesktopUX.ViewModels"
        Title="Power Platform Productivity Engine Suite (.NET 9)" Height="920" Width="1420"
        Icon="Resources/app_logo.png"
        Background="#0F172A" Foreground="#F8FAFC" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR & GLOBAL OAUTH DISCOVERY -->
        <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,0,10" BorderBrush="#334155" BorderThickness="1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- App Logo Image Badge -->
                    <Image Source="Resources/app_logo.png" Width="28" Height="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="⚡ POWER PLATFORM ENGINE SUITE" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="🔑 Discover Envs (OAuth)" Command="{Binding DiscoverEnvironmentsCommand}" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="12,6" Margin="0,0,8,0" BorderThickness="0"/>
                    <CheckBox Content="Simulation Mode (Offline Demo)" IsChecked="{Binding IsSimulationMode}" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <Button Content="📊 Export HTML Dashboard" Command="{Binding ExportHtmlCommand}" Background="#334155" Foreground="White" Padding="10,6" Margin="0,0,6,0" BorderThickness="0"/>
                    <Button Content="📗 Export Formatted Excel" Command="{Binding ExportExcelCommand}" Background="#0D9488" Foreground="White" FontWeight="Bold" Padding="10,6" Margin="0,0,6,0" BorderThickness="0"/>
                    <Button Content="🗄️ Save Offline SQLite" Command="{Binding SaveToSqliteCommand}" Background="#4338CA" Foreground="White" Padding="10,6" BorderThickness="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- PROGRESS & STATUS BANNER (VISIBLE WHEN PROCESSING) -->
        <Border Grid.Row="1" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Background="#1E293B" CornerRadius="6" Padding="10,8" Margin="0,0,0,10" BorderBrush="#0284C7" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6" LastChildFill="True">
                    <TextBlock Text="⏳ PROCESSING IN PROGRESS: " FontWeight="Bold" Foreground="#38BDF8" FontSize="12" DockPanel.Dock="Left"/>
                    <TextBlock Text="{Binding ProgressDetails}" Foreground="#F8FAFC" FontSize="12" TextTrimming="CharacterEllipsis"/>
                </DockPanel>
                <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="8" Background="#0F172A" Foreground="#0284C7" BorderThickness="0"/>
            </Grid>
        </Border>

        <!-- DYNAMIC WORKSPACE TABS SYSTEM -->
        <TabControl Grid.Row="2" ItemsSource="{Binding WorkspaceTabs}" SelectedIndex="{Binding SelectedTabIndex}" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
            <!-- DYNAMIC TAB HEADER -->
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="{Binding Title}" Foreground="#38BDF8" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                        <Button Content="❌" Command="{Binding CloseCommand}" Visibility="{Binding CanClose, Converter={StaticResource BoolToVis}}" Background="Transparent" Foreground="#94A3B8" BorderThickness="0" Margin="6,0,0,0" Padding="2,0" FontSize="10" Cursor="Hand"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <!-- DYNAMIC TAB CONTENT TEMPLATES -->
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Margin="0,10,0,0">
                        <!-- TEMPLATE 0: LANDING PAGE WITH 2 CHILD TABS (REGISTRY & MODULE SUITE) -->
                        <TabControl Background="Transparent" BorderThickness="0">
                            <TabControl.Style>
                                <Style TargetType="TabControl">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="LandingPage">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TabControl.Style>

                            <!-- CHILD TAB 1: MASTER ENVIRONMENTS REGISTRY (FULL PAGE REAL ESTATE) -->
                            <TabItem Header="🌐 Master Environments Registry" Foreground="#38BDF8" FontWeight="Bold" Padding="12,6">
                                <Border Background="#1E293B" CornerRadius="8" Padding="16" Margin="0,10,0,0" BorderBrush="#334155" BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                                <TextBlock Text="🌐 MASTER ENVIRONMENTS REGISTRY" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="(Global tenant environment repository)" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <!-- Wildcard Search Box Placed Directly BEFORE Sort / Group Dropdown -->
                                                <TextBlock Text="🔍 Search (*): " Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                                                <TextBox Text="{Binding DataContext.EnvSearchText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" 
                                                         Background="#0F172A" Foreground="#F8FAFC" BorderBrush="#334155" Padding="6,3" Margin="0,0,12,0" FontSize="11" Width="180" 
                                                         ToolTip="Supports Wildcard Search, e.g. *dev*, *sandbox*, *prod*, contoso*"/>

                                                <TextBlock Text="Sort / Group: " Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="11"/>
                                                
                                                <!-- High Contrast Dark Styled ComboBox -->
                                                <ComboBox ItemsSource="{Binding DataContext.SortOptions, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                          SelectedItem="{Binding DataContext.SelectedSortOption, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                          Background="#0F172A" Foreground="#F8FAFC" BorderBrush="#334155" Padding="6,3" Margin="0,0,10,0" FontSize="11" Width="145">
                                                    <ComboBox.ItemContainerStyle>
                                                        <Style TargetType="ComboBoxItem">
                                                            <Setter Property="Background" Value="#1E293B"/>
                                                            <Setter Property="Foreground" Value="#F8FAFC"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#0284C7"/>
                                                                    <Setter Property="Foreground" Value="#FFFFFF"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ComboBox.ItemContainerStyle>
                                                </ComboBox>

                                                <Button Content="🛡️ Check if Admin" Command="{Binding DataContext.CheckAdminAccessCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#4338CA" Foreground="White" FontWeight="Bold" Padding="10,5" Margin="0,0,6,0" FontSize="11" BorderThickness="0" ToolTip="Check System Administrator role access across tenant environments"/>
                                                <Button Content="➕ Add Env URL" Command="{Binding DataContext.AddManualEnvCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="8,5" FontSize="11" BorderThickness="0"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <!-- Full Page Master Environments Registry ListBox -->
                                        <ListBox Grid.Row="1" ItemsSource="{Binding DataContext.FilteredEnvironments, RelativeSource={RelativeSource AncestorType=Window}}" Background="#0F172A" BorderBrush="#334155">
                                            <ListBox.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                                </ItemsPanelTemplate>
                                            </ListBox.ItemsPanel>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1E293B" CornerRadius="8" Padding="12" Margin="6" Width="340" BorderBrush="#334155" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <DockPanel Grid.Row="0" LastChildFill="True">
                                                                <Button Content="ℹ️ More Info" Command="{Binding DataContext.OpenEnvDetailsCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" DockPanel.Dock="Right" Background="#334155" Foreground="#38BDF8" FontSize="10" Padding="6,2" VerticalAlignment="Top" BorderThickness="0" Cursor="Hand" ToolTip="View assigned security roles and detailed environment metadata"/>
                                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="#F8FAFC"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </DockPanel>
                                                            <TextBlock Grid.Row="1" Text="{Binding Url}" Foreground="#38BDF8" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </TabItem>

                            <!-- CHILD TAB 2: MODULE LAUNCHER SUITE (FULL PAGE REAL ESTATE) -->
                            <TabItem Header="🚀 Engine Module Suite &amp; Launcher" Foreground="#38BDF8" FontWeight="Bold" Padding="12,6">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                                    <StackPanel>
                                        <TextBlock Text="🚀 ENGINE MODULE SUITE &amp; WORKSPACE LAUNCHER" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" Margin="4,0,0,12"/>
                                        
                                        <UniformGrid Columns="4" Margin="0,0,0,12">
                                            <!-- MODULE 7 CARD -->
                                            <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="6" BorderBrush="#0284C7" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="🌐 Environment Comparator &amp; Solution Explorer" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1" Text="N-Way multi-environment matrix comparison, Root 1 &amp; Root 2 Solution Explorer tree, side-by-side property diffing, de-compiled code &amp; form XML viewer." Foreground="#CBD5E1" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                    <Button Grid.Row="2" Content="▶️ Open Module in New Tab" Command="{Binding DataContext.OpenModuleTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Module7" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="10,6" BorderThickness="0"/>
                                                </Grid>
                                            </Border>

                                            <!-- MODULE 2 CARD -->
                                            <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="6" BorderBrush="#0284C7" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="🔍 Solution Deep Validator" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1" Text="Executes 19 deep static analysis &amp; compliance checkers on solution ZIP packages across single or multi-tenant environments." Foreground="#CBD5E1" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                    <Button Grid.Row="2" Content="▶️ Open Module in New Tab" Command="{Binding DataContext.OpenModuleTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Module2" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="10,6" BorderThickness="0"/>
                                                </Grid>
                                            </Border>

                                            <!-- MODULE 1 CARD -->
                                            <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="6" BorderBrush="#0284C7" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="🔧 Solution Repair &amp; Distiller" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1" Text="Repairs corrupt solution XML syntax and distills OOB table bloat across environments automatically." Foreground="#CBD5E1" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                    <Button Grid.Row="2" Content="▶️ Open Module in New Tab" Command="{Binding DataContext.OpenModuleTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Module1" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="10,6" BorderThickness="0"/>
                                                </Grid>
                                            </Border>

                                            <!-- MODULE 3 CARD -->
                                            <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="6" BorderBrush="#0284C7" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="👥 Security Role Lifecycle Manager" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1" Text="Audits user security role drift, business unit assignments, and bulk-synchronizes security roles across tenant environments." Foreground="#CBD5E1" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                    <Button Grid.Row="2" Content="▶️ Open Module in New Tab" Command="{Binding DataContext.OpenModuleTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Module3" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="10,6" BorderThickness="0"/>
                                                </Grid>
                                            </Border>

                                            <!-- MODULE 4 CARD -->
                                            <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="6" BorderBrush="#334155" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="⚡ Web Resource &amp; JS Transpiler Sync" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1" Text="Diffs TypeScript/JS web resources and deploys live updates directly to Dataverse environments." Foreground="#CBD5E1" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                    <Button Grid.Row="2" Content="▶️ Open Module in New Tab" Command="{Binding DataContext.OpenModuleTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Module4" Background="#334155" Foreground="White" Padding="10,6" BorderThickness="0"/>
                                                </Grid>
                                            </Border>

                                            <!-- MODULE 5 CARD -->
                                            <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="6" BorderBrush="#334155" BorderThickness="1">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Text="🔌 Plugin Step Diff Engine" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                    <TextBlock Grid.Row="1" Text="De-compiles C# assemblies, diffs plugin steps, filtering attributes, and execution order across environments." Foreground="#CBD5E1" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                                    <Button Grid.Row="2" Content="▶️ Open Module in New Tab" Command="{Binding DataContext.OpenModuleTabCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Module5" Background="#334155" Foreground="White" Padding="10,6" BorderThickness="0"/>
                                                </Grid>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>

                        <!-- TEMPLATE: CONSOLE LOG (PERMANENT PINNED TAB) -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="ConsoleLog">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- TOP CONSOLE TOOLBAR -->
                                <Border Grid.Row="0" Background="#1E293B" CornerRadius="6" Padding="12,8" Margin="0,0,0,10" BorderBrush="#334155" BorderThickness="1">
                                    <DockPanel LastChildFill="False">
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                            <TextBlock Text="📜 SYSTEM EXECUTION CONSOLE" FontSize="14" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Text="Real-time Web API stream &amp; engine execution diagnostics" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                            <Button Content="🗑️ Clear Console" Command="{Binding DataContext.ClearConsoleCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#334155" Foreground="White" Padding="8,4" Margin="0,0,6,0" FontSize="11" BorderThickness="0"/>
                                            <Button Content="💾 Export Log File" Command="{Binding DataContext.ExportConsoleLogsCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="10,4" FontSize="11" BorderThickness="0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- 2 VERTICAL PANELS CONSOLE LAYOUT (PANEL 1 TOP: INFO STREAM, PANEL 2 BOTTOM: ERRORS & WARNINGS) -->
                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="6*"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="4*"/>
                                    </Grid.RowDefinitions>

                                    <!-- TOP PANEL 1: EXECUTION & INFO LOG STREAM -->
                                    <Border Grid.Row="0" Background="#020617" CornerRadius="6" Padding="8" BorderBrush="#1E293B" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel Grid.Row="0" Margin="4,2,4,8">
                                                <TextBlock Text="ℹ️ EXECUTION &amp; INFO LOG STREAM" FontWeight="Bold" Foreground="#38BDF8" FontSize="12" DockPanel.Dock="Left"/>
                                                <TextBlock Text="Web API, MSAL Authentication, &amp; Engine Metadata Crawling (Saved to SQLite)" Foreground="#64748B" FontSize="11" DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <ListBox Grid.Row="1" ItemsSource="{Binding DataContext.InfoConsoleLogs, RelativeSource={RelativeSource AncestorType=Window}}" Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="12">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                                            <TextBlock Text="[" Foreground="#64748B"/>
                                                            <TextBlock Text="{Binding FormattedTimestamp}" Foreground="#38BDF8"/>
                                                            <TextBlock Text="] [" Foreground="#64748B"/>
                                                            <TextBlock Text="{Binding Level}" FontWeight="Bold" Width="60">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#38BDF8"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Success">
                                                                                <Setter Property="Foreground" Value="#34D399"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Progress">
                                                                                <Setter Property="Foreground" Value="#A855F7"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="] [" Foreground="#64748B"/>
                                                            <TextBlock Text="{Binding Category}" Foreground="#F59E0B" Width="90"/>
                                                            <TextBlock Text="] " Foreground="#64748B"/>
                                                            <TextBlock Text="{Binding Message}" Foreground="#F8FAFC" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>

                                    <!-- HORIZONTAL GRID SPLITTER -->
                                    <GridSplitter Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="#334155"/>

                                    <!-- BOTTOM PANEL 2: ERRORS & WARNINGS DIAGNOSTICS PANEL -->
                                    <Border Grid.Row="2" Background="#0F172A" CornerRadius="6" Padding="8" BorderBrush="#EF4444" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel Grid.Row="0" Margin="4,2,4,8">
                                                <TextBlock Text="⚠️ ERRORS &amp; WARNINGS DIAGNOSTICS" FontWeight="Bold" Foreground="#EF4444" FontSize="12" DockPanel.Dock="Left"/>
                                                <TextBlock Text="Filtered Failures &amp; Exceptions (Saved to SQLite)" Foreground="#F59E0B" FontSize="11" DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <ListBox Grid.Row="1" ItemsSource="{Binding DataContext.ErrorConsoleLogs, RelativeSource={RelativeSource AncestorType=Window}}" Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="12">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,3">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="[" Foreground="#64748B"/>
                                                                <TextBlock Text="{Binding FormattedTimestamp}" Foreground="#EF4444"/>
                                                                <TextBlock Text="] [" Foreground="#64748B"/>
                                                                <TextBlock Text="{Binding Level}" FontWeight="Bold" Foreground="#F59E0B"/>
                                                                <TextBlock Text="] [" Foreground="#64748B"/>
                                                                <TextBlock Text="{Binding Category}" Foreground="#F8FAFC"/>
                                                                <TextBlock Text="]" Foreground="#64748B"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Message}" Foreground="#FCA5A5" TextWrapping="Wrap" Margin="10,2,0,0"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>

                        <!-- TEMPLATE 1: MODULE 7 (COMPARATOR) -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="Comparator">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- TOP COMPARATOR ACTION BAR -->
                            <Border Grid.Row="0" Background="#1E293B" CornerRadius="8" Padding="12,8" Margin="0,0,0,10" BorderBrush="#334155" BorderThickness="1">
                                <DockPanel LastChildFill="False">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                                        <TextBlock Text="🔄 ENVIRONMENT COMPARATOR &amp; EXPLODED TREE EXPLORER" FontSize="14" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Text="Select target environments &amp; check components to compare" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button Content="🚀 RUN COMPARISON ON CHECKED ITEMS" Command="{Binding DataContext.CompareEnvironmentsCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#166534" Foreground="White" FontWeight="Bold" Padding="14,6" Margin="0,0,8,0" FontSize="12" BorderThickness="0" Cursor="Hand" ToolTip="Execute N-Way comparison on checked tree items across selected environments"/>
                                        <Button Content="☑️ Select All Tree" Command="{Binding DataContext.SelectAllTreeNodesCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="8,6" Margin="0,0,4,0" FontSize="11" BorderThickness="0"/>
                                        <Button Content="🔲 Select None Tree" Command="{Binding DataContext.SelectNoneTreeNodesCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#475569" Foreground="White" Padding="8,6" FontSize="11" BorderThickness="0"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="450"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#1E293B" CornerRadius="8" Padding="12" Margin="0,0,12,0" BorderBrush="#334155" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="200" MinHeight="100"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <DockPanel Grid.Row="0" Margin="0,0,0,4" LastChildFill="False">
                                            <TextBlock Text="🌐 ENVIRONMENTS" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="🛡️ Check if Admin" Command="{Binding DataContext.CheckAdminAccessCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#4338CA" Foreground="White" Padding="5,2" Margin="0,0,4,0" FontSize="10" BorderThickness="0"/>
                                                <Button Content="☑️ All" Command="{Binding DataContext.SelectAllEnvsCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#334155" Foreground="White" Padding="5,2" Margin="0,0,4,0" FontSize="10" BorderThickness="0"/>
                                                <Button Content="🔲 None" Command="{Binding DataContext.SelectNoneEnvsCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#334155" Foreground="White" Padding="5,2" Margin="0,0,4,0" FontSize="10" BorderThickness="0"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <TextBox Grid.Row="1" Text="{Binding DataContext.EnvSearchText, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Background="#0F172A" Foreground="#F8FAFC" BorderBrush="#334155" Padding="6,4" Margin="0,0,0,6" FontSize="12"/>

                                        <ListBox Grid.Row="2" ItemsSource="{Binding DataContext.FilteredEnvironments, RelativeSource={RelativeSource AncestorType=Window}}" Background="#0F172A" BorderBrush="#334155">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected}" Margin="4,2">
                                                        <CheckBox.Style>
                                                            <Style TargetType="CheckBox">
                                                                <Setter Property="Foreground" Value="#F8FAFC"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAdmin}" Value="True">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </CheckBox.Style>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>

                                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#334155" Cursor="SizeNS"/>

                                    <DockPanel Grid.Row="2" Margin="0,6,0,6" LastChildFill="False">
                                        <TextBlock Text="📁 EXPLODED SOLUTION EXPLORER TREE" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button Content="☑️ Select All" Command="{Binding DataContext.SelectAllTreeNodesCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="6,3" Margin="0,0,4,0" FontSize="10" BorderThickness="0"/>
                                            <Button Content="🔲 Select None" Command="{Binding DataContext.SelectNoneTreeNodesCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#475569" Foreground="White" Padding="6,3" Margin="0,0,6,0" FontSize="10" BorderThickness="0"/>
                                            <Button Content="🚀 Compare Selected" Command="{Binding DataContext.CompareEnvironmentsCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#166534" Foreground="White" FontWeight="Bold" Padding="8,3" Margin="0,0,4,0" FontSize="11" BorderThickness="0"/>
                                            <Button Content="➕ Expand" Command="{Binding DataContext.ExpandAllCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#334155" Foreground="White" Padding="6,3" Margin="0,0,2,0" FontSize="10" BorderThickness="0"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <TreeView Grid.Row="3" ItemsSource="{Binding DataContext.UnifiedSolutionExplorerTree, RelativeSource={RelativeSource AncestorType=Window}}" SelectedItemChanged="TreeView_SelectedItemChanged" Background="#0F172A" Foreground="#F8FAFC" BorderThickness="0">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                                <Setter Property="Foreground" Value="#F8FAFC"/>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                <StackPanel Orientation="Horizontal" Margin="2">
                                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="#F8FAFC" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Status}" Foreground="#38BDF8" FontSize="11" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </Grid>
                            </Border>

                            <Border Grid.Column="1" Background="#1E293B" CornerRadius="8" Padding="14" BorderBrush="#334155" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔍 SELECTED ITEM: " FontWeight="Bold" Foreground="#94A3B8" FontSize="14"/>
                                            <TextBlock Text="{Binding DataContext.SelectedNode.DisplayName, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue='(Select an item in left tree)'}" FontWeight="Bold" Foreground="#38BDF8" FontSize="14"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TabControl Grid.Row="1" ItemsSource="{Binding DataContext.EnvDetailTabs, RelativeSource={RelativeSource AncestorType=Window}}" Background="Transparent" BorderThickness="0">
                                        <TabControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Header}" Foreground="#38BDF8" FontWeight="Bold" FontSize="12" Margin="4,2"/>
                                            </DataTemplate>
                                        </TabControl.ItemTemplate>
                                        <TabControl.ContentTemplate>
                                            <DataTemplate>
                                                <Border Background="#0F172A" CornerRadius="6" Padding="10" Margin="0,6,0,0">
                                                    <Grid>
                                                        <DataGrid ItemsSource="{Binding Properties}" AutoGenerateColumns="False" IsReadOnly="True" Background="#0F172A" Foreground="#F8FAFC" RowBackground="#1E293B" AlternatingRowBackground="#0F172A" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#334155">
                                                            <DataGrid.Style>
                                                                <Style TargetType="DataGrid">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ContentType}" Value="PropertyGrid">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </DataGrid.Style>
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="Property / Attribute" Binding="{Binding Key}" Width="240"/>
                                                                <DataGridTextColumn Header="Value / Configuration" Binding="{Binding Value}" Width="*"/>
                                                            </DataGrid.Columns>
                                                        </DataGrid>

                                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                                            <ScrollViewer.Style>
                                                                <Style TargetType="ScrollViewer">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ContentType}" Value="CodeEditor">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding ContentType}" Value="XmlViewer">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ScrollViewer.Style>
                                                            <TextBox Text="{Binding RawCodeContent}" IsReadOnly="True" FontFamily="Consolas, Cascadia Code, Courier New" FontSize="13" Background="#0F172A" Foreground="#38BDF8" BorderThickness="0" Padding="8"/>
                                                        </ScrollViewer>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </TabControl.ContentTemplate>
                                    </TabControl>
                                </Grid>
                            </Border>
                            </Grid>
                        </Grid>

                        <!-- TEMPLATE 2: MODULE 2 (DEEP VALIDATOR) -->
                        <Border Background="#1E293B" CornerRadius="8" Padding="16" BorderBrush="#334155" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="DeepValidator">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                    <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                        <TextBlock Text="🔍 SOLUTION DEEP VALIDATION SCANNER (19 CHECKERS)" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                            <Button Content="📊 Export HTML" Command="{Binding DataContext.ExportValHtmlCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#334155" Foreground="White" Padding="10,4" Margin="0,0,6,0" BorderThickness="0"/>
                                            <Button Content="📗 Export Formatted Excel" Command="{Binding DataContext.ExportValExcelCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#0D9488" Foreground="White" FontWeight="Bold" Padding="10,4" BorderThickness="0"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding DataContext.ValZipPath, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" Background="#0F172A" Foreground="#F8FAFC" BorderBrush="#334155" Padding="8,6"/>
                                        <Button Grid.Column="1" Content="📁 Browse Solution ZIP..." Command="{Binding DataContext.BrowseValZipCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#334155" Foreground="White" Padding="12,6" Margin="8,0,0,0" BorderThickness="0"/>
                                    </Grid>
                                    <Button Content="▶️ Run 19 Deep Validation Checkers Across Selected Environments" Command="{Binding DataContext.RunValidationCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="16,8" HorizontalAlignment="Left" BorderThickness="0"/>
                                </StackPanel>

                                <Border Grid.Row="1" Background="#0F172A" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding DataContext.ValResultSummary, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#F8FAFC" FontWeight="SemiBold"/>
                                </Border>

                                <DataGrid Grid.Row="2" ItemsSource="{Binding DataContext.ValidationIssues, RelativeSource={RelativeSource AncestorType=Window}}" AutoGenerateColumns="False" IsReadOnly="True" Background="#0F172A" Foreground="#F8FAFC" RowBackground="#1E293B" AlternatingRowBackground="#0F172A" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#334155">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Issue ID" Binding="{Binding Id}" Width="120"/>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100"/>
                                        <DataGridTextColumn Header="Component" Binding="{Binding ComponentType}" Width="140"/>
                                        <DataGridTextColumn Header="Logical Name" Binding="{Binding LogicalName}" Width="200"/>
                                        <DataGridTextColumn Header="Description &amp; Remediation" Binding="{Binding Description}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!-- TEMPLATE 3: MODULE 1 (SOLUTION REPAIR) -->
                        <Border Background="#1E293B" CornerRadius="8" Padding="16" BorderBrush="#334155" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="SolutionRepair">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                    <TextBlock Text="🔧 AUTOMATED SOLUTION REPAIR &amp; DISTILLER" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,12"/>
                                    <Button Content="⚡ Execute XML Syntax Repair &amp; OOB Table Bloat Distillation" Command="{Binding DataContext.RunRepairDistillCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#166534" Foreground="White" FontWeight="Bold" Padding="16,10" HorizontalAlignment="Left" BorderThickness="0"/>
                                </StackPanel>

                                <Border Grid.Row="1" Background="#0F172A" CornerRadius="6" Padding="14">
                                    <ScrollViewer>
                                        <TextBlock Text="{Binding DataContext.RepairLogMessage, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#38BDF8" FontFamily="Consolas, Courier New" FontSize="13"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- TEMPLATE 4: MODULE 3 (SECURITY ROLE MANAGER) -->
                        <Border Background="#1E293B" CornerRadius="8" Padding="16" BorderBrush="#334155" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Type}" Value="SecurityRoleManager">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Margin="0,0,0,16">
                                    <TextBlock Text="👥 MULTI-ENVIRONMENT USER &amp; SECURITY ROLE MANAGER" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="🔍 Audit Role Drift Across Envs" Command="{Binding DataContext.RunRoleAuditCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#334155" Foreground="White" FontWeight="Bold" Padding="14,8" Margin="0,0,10,0" BorderThickness="0"/>
                                        <Button Content="⚡ Bulk Synchronize Security Roles" Command="{Binding DataContext.RunRoleSyncCommand, RelativeSource={RelativeSource AncestorType=Window}}" Background="#4338CA" Foreground="White" FontWeight="Bold" Padding="16,8" BorderThickness="0"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Row="1" Background="#0F172A" CornerRadius="6" Padding="14">
                                    <ScrollViewer>
                                        <TextBlock Text="{Binding DataContext.RoleLogMessage, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#38BDF8" FontFamily="Consolas, Courier New" FontSize="13"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

        <!-- STATUS BAR -->
        <Border Grid.Row="3" Background="#0F172A" Padding="6,4">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#94A3B8" FontSize="12"/>
        </Border>
    </Grid>
</Window>
