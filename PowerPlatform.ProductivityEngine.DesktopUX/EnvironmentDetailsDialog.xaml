<Window x:Class="PowerPlatform.ProductivityEngine.DesktopUX.EnvironmentDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Environment Details &amp; Security Roles" Height="680" Width="820"
        Background="#0F172A" Foreground="#F8FAFC" WindowStartupLocation="CenterOwner">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12" LastChildFill="False">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock x:Name="TxtTitle" Text="🌐 Environment Details &amp; Security Roles" FontSize="18" FontWeight="Bold" Foreground="#38BDF8" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="🔄 Refresh Local Cache" Click="OnRefreshClick" Background="#0284C7" Foreground="White" FontWeight="Bold" Padding="10,6" Margin="0,0,8,0" BorderThickness="0"/>
                <Button Content="✖️ Close" Click="OnCloseClick" Background="#334155" Foreground="White" Padding="10,6" BorderThickness="0"/>
            </StackPanel>
        </DockPanel>

        <!-- STATUS BANNER -->
        <Border Grid.Row="1" x:Name="StatusBanner" Background="#1E293B" CornerRadius="6" Padding="10,8" Margin="0,0,0,12" BorderBrush="#0284C7" BorderThickness="1">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="TxtStatus" Text="Loading details from SQLite cache..." Foreground="#F8FAFC" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- MAIN SCROLLABLE CONTENT -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- SECTION 1: ASSIGNED SECURITY ROLES -->
                <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="0,0,0,14" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <DockPanel LastChildFill="False" Margin="0,0,0,8">
                            <TextBlock Text="🛡️ ASSIGNED SECURITY ROLES (FOR CURRENT USER)" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="TxtRoleCount" Text="Count: 0" Foreground="#94A3B8" FontSize="12" DockPanel.Dock="Right"/>
                        </DockPanel>
                        <ItemsControl x:Name="RolesItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F172A" CornerRadius="6" Padding="8,4" Margin="4" BorderBrush="#0284C7" BorderThickness="1">
                                        <TextBlock Text="{Binding}" Foreground="#38BDF8" FontWeight="SemiBold" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- SECTION 2: USER & IDENTITY DETAILS -->
                <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="0,0,0,14" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="👤 USER &amp; IDENTITY METADATA" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" Margin="0,0,0,10"/>
                        <DataGrid x:Name="GridUserDetails" AutoGenerateColumns="False" IsReadOnly="True" Background="#0F172A" Foreground="#F8FAFC" RowBackground="#1E293B" AlternatingRowBackground="#0F172A" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#334155">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="User Attribute" Binding="{Binding Key}" Width="200"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- SECTION 3: DATAVERSE ENVIRONMENT & ORG METADATA -->
                <Border Background="#1E293B" CornerRadius="8" Padding="14" Margin="0,0,0,14" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🏢 DATAVERSE ENVIRONMENT &amp; ORG METADATA" FontWeight="Bold" Foreground="#38BDF8" FontSize="13" Margin="0,0,0,10"/>
                        <DataGrid x:Name="GridOrgDetails" AutoGenerateColumns="False" IsReadOnly="True" Background="#0F172A" Foreground="#F8FAFC" RowBackground="#1E293B" AlternatingRowBackground="#0F172A" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#334155">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Org Attribute" Binding="{Binding Key}" Width="200"/>
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- BOTTOM TOOLBAR -->
        <Border Grid.Row="3" Background="#0F172A" Padding="8,6" Margin="0,10,0,0">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="TxtFooter" Text="Cached in Local SQLite DB" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <Button Content="Close" Click="OnCloseClick" Background="#334155" Foreground="White" Width="90" Height="28" DockPanel.Dock="Right" BorderThickness="0"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
